# Preferred for automatic speaker identification / diarization in local development.
# Uses Deepgram Nova live transcription with diarization.
VITE_DEEPGRAM_API_KEY=

# Optional alternate backend for automatic speaker identification / diarization.
VITE_AZURE_SPEECH_KEY=
VITE_AZURE_SPEECH_REGION=

# Without Deepgram or Azure credentials, the app falls back to Chrome Web Speech,
# which transcribes but cannot identify speakers automatically.
